# Paycorp Gateway Configuration
# Copy this file to .env and fill in your credentials

# Gateway API Endpoint
PAYCORP_SERVICE_ENDPOINT=https://sampath.paycorp.lk/rest/service/proxy

# Authentication Credentials (provided by Paycorp)
PAYCORP_AUTH_TOKEN=your_auth_token_here
PAYCORP_HMAC_SECRET=your_hmac_secret_here
PAYCORP_CLIENT_ID=your_client_id_here

# Optional: Server Configuration
PORT=3000
