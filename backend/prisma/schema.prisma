// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ─────────────────────────────────────────────────────────────────
model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String       @map("password_hash")
  name         String
  createdAt    DateTime     @default(now()) @map("created_at")

  orders       Order[]
  userCourses  UserCourse[]

  @@map("users")
}

// ─── Courses (individual subjects) ─────────────────────────────────────────
model Course {
  id          String  @id                    // e.g. "BA1", "E1"
  name        String
  price       Int                            // in LKR (whole units, e.g. 16000)
  level       String                         // certificate | operational | management | strategic
  slug        String  @unique
  description String? @db.Text
  icon        String?
  subtitle    String?
  highlights  String[]
  syllabus    Json    @default("[]")
  outcomes    String[]
  lecturerName String? @map("lecturer_name")

  combinationItems CourseCombinationItem[]
  userCourses      UserCourse[]

  @@map("courses")
}

// ─── Course Combinations ────────────────────────────────────────────────────
model CourseCombination {
  id    String @id                           // e.g. "cert_ba1_ba2"
  level String
  price Int                                  // total price in LKR

  items  CourseCombinationItem[]
  orders Order[]

  @@map("course_combinations")
}

model CourseCombinationItem {
  id            String @id @default(uuid())
  combinationId String @map("combination_id")
  courseId      String @map("course_id")

  combination CourseCombination @relation(fields: [combinationId], references: [id])
  course      Course             @relation(fields: [courseId], references: [id])

  @@unique([combinationId, courseId])
  @@map("course_combination_items")
}

// ─── Orders ─────────────────────────────────────────────────────────────────
model Order {
  id              String      @id @default(uuid())
  userId          String?     @map("user_id")
  combinationId   String      @map("combination_id")
  amount          Int                                // in LKR
  status          OrderStatus @default(PENDING)
  ipgMerchantRef  String?     @map("ipg_merchant_ref")
  ipgRef          String?     @map("ipg_ref")        // returned by IPG after payment
  currency        String      @default("LKR")         // payment currency (GBP | LKR)
  // Guest details (stored when no user account exists)
  guestName       String?     @map("guest_name")
  guestEmail      String?     @map("guest_email")
  guestPhone      String?     @map("guest_phone")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt             @map("updated_at")

  user        User?              @relation(fields: [userId], references: [id])
  combination CourseCombination  @relation(fields: [combinationId], references: [id])
  userCourses UserCourse[]

  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ─── UserCourses (access grants) ────────────────────────────────────────────
model UserCourse {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  courseId  String   @map("course_id")
  orderId   String   @map("order_id")
  grantedAt DateTime @default(now()) @map("granted_at")

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])

  @@unique([userId, courseId])
  @@map("user_courses")
}

// ─── Admin Users ─────────────────────────────────────────────────────────────
model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         AdminRole @default(admin)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("admin_users")
}

enum AdminRole {
  admin
  superadmin
}

// ─── Blog Posts ──────────────────────────────────────────────────────────────
model BlogPost {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  coverUrl    String?  @map("cover_url")
  content     String   @db.Text
  published   Boolean  @default(false)
  authorId    String?  @map("author_id")
  metaTitle   String?  @map("meta_title")
  metaDesc    String?  @map("meta_desc")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("blog_posts")
}

// ─── Lecturers ───────────────────────────────────────────────────────────────
model Lecturer {
  id          String   @id @default(uuid())
  name        String
  title       String
  credentials String[]
  bio         String   @db.Text
  bio2        String?  @db.Text
  imageUrl    String?  @map("image_url")
  stats       Json     @default("[]")
  specialties String[]
  sortOrder   Int      @default(0) @map("sort_order")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("lecturers")
}

// ─── Site Settings ───────────────────────────────────────────────────────────
model SiteSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  category  String   @default("general")
  label     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

// ─── Page Meta Tags ───────────────────────────────────────────────────────────
model PageMeta {
  id          String   @id @default(uuid())
  pagePath    String   @unique @map("page_path")
  pageTitle   String   @map("page_title")
  metaTitle   String?  @map("meta_title")
  metaDesc    String?  @map("meta_desc")
  metaKeywords String? @map("meta_keywords")
  ogTitle     String?  @map("og_title")
  ogDesc      String?  @map("og_desc")
  ogImage     String?  @map("og_image")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("page_meta")
}

// ─── Newsletter Signups ───────────────────────────────────────────────────────
model NewsletterSignup {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("newsletter_signups")
}

// ─── Contact Form Submissions ─────────────────────────────────────────────────
model ContactSubmission {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_submissions")
}

// ─── Testimonials ─────────────────────────────────────────────────────────────
model Testimonial {
  id           String   @id @default(uuid())
  studentName  String   @map("student_name")
  country      String
  flag         String
  tag          String
  exam         String
  period       String
  year         Int
  marks        Int?
  imageUrl     String?  @map("image_url")
  quote        String   @db.Text
  videoUrl     String?  @map("video_url")
  badge        String?
  isPrizeWinner Boolean @default(false)         @map("is_prize_winner")
  published    Boolean  @default(true)
  sortOrder    Int      @default(0)             @map("sort_order")
  createdAt    DateTime @default(now())         @map("created_at")
  updatedAt    DateTime @updatedAt              @map("updated_at")

  @@map("testimonials")
}
