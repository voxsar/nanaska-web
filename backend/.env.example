# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/nanaska?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Media / Image Uploads ─────────────────────────────────────────────────────
# Public base URL of this backend (used to construct uploaded image URLs)
API_BASE_URL=http://localhost:3001

# ─── Payment Gateway (PayHere example) ────────────────────────────────────────
# Replace these values with your actual IPG credentials
IPG_MERCHANT_ID=1234567
IPG_MERCHANT_SECRET=your_merchant_secret_here
IPG_BASE_URL=https://sandbox.payhere.lk/pay/checkout
IPG_NOTIFY_URL=https://your-backend-domain.com/payments/webhook
IPG_RETURN_URL=https://your-frontend-domain.com/payment-success
IPG_CANCEL_URL=https://your-frontend-domain.com/payment-cancel
IPG_CURRENCY=LKR
# LKR gateway client ID
IPG_CLIENT_ID=your_lkr_client_id_here
# GBP gateway client ID (international payments)
IPG_GBP_CLIENT_ID=14004406

# ─── Google Sheets Integration ───────────────────────────────────────────────
# Optional: Enable Google Sheets auto-sync for enrollment submissions
# Service account credentials JSON (as a single-line string)
GOOGLE_SHEETS_CREDENTIALS={"type":"service_account","project_id":"your-project",...}
# The Google Sheets spreadsheet ID (from the URL)
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
# Sheet name/tab within the spreadsheet (defaults to "Enrollment Submissions")
GOOGLE_SHEETS_SHEET_NAME=Enrollment Submissions
